# Appwrite Configuration
# Copy this file to .env and fill in your actual values

# Appwrite Endpoint URL
# Example: https://cloud.appwrite.io/v1
EXPO_PUBLIC_APPWRITE_ENDPOINT=your_appwrite_endpoint_here

# Appwrite Project ID
# Get this from your Appwrite console
EXPO_PUBLIC_APPWRITE_PROJECT_ID=your_project_id_here

# Appwrite Database ID
EXPO_PUBLIC_APPWRITE_DATABASE_ID=your_database_id_here

# Appwrite Bucket ID (for image storage)
EXPO_PUBLIC_APPWRITE_BUCKET_ID=your_bucket_id_here

# Instructions:
# 1. Create a new file named .env in the root directory
# 2. Copy the contents of this file
# 3. Replace the placeholder values with your actual Appwrite credentials
# 4. Never commit .env to version control (it's already in .gitignore)
